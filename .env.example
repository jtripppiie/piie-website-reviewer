PORT=3000
ADMIN_PASSWORD=change-me

# Reviewer access
REVIEW_USERNAME=PIIE
REVIEW_PASSWORD=change-me-too

# Optional. If set, reviewers must enter this password once per browser
# session before they can use quick edit. Leave blank to disable the gate.
QUICK_EDIT_PASSWORD=

# Leave this unset (or set it to local) for normal local JSON/file storage.
# Cloud Run sets it to google and supplies the bucket/project values.
STORAGE_BACKEND=local
GCS_BUCKET=
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DATABASE=
FIRESTORE_COLLECTION_PREFIX=piie_reviewer
