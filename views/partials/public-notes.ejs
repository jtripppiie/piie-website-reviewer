<%
  const visibleNotes = responses.filter(response => {
    const samePage = response.pageId === page.pageId;
    const sameScreen = (screenSize || '') === (response.screenSize || '');
    return samePage && sameScreen;
  });

  function statusLabel(status) {
    const labels = {
      'approved': 'Approved',
      'approved-minor-changes': 'Approved after these changes',
      'approved-after-these-changes': 'Approved after these changes',
      'needs-design-changes': 'Needs design changes',
      'needs-content-changes': 'Needs content changes',
      'needs-mobile-review': 'Needs mobile review',
      'blocked-cannot-review': 'Blocked / cannot review',
      'not-approved': 'Not approved'
    };

    return labels[status] || status || 'Review note';
  }

  function statusIcon(status) {
    if (status === 'approved') return '✓';
    if (status === 'not-approved' || status === 'blocked-cannot-review') return '×';
    if (status === 'approved-minor-changes' || status === 'approved-after-these-changes') return '↻';
    return '!';
  }

  function statusClass(status) {
    if (status === 'approved') return 'is-approved';
    if (status === 'not-approved' || status === 'blocked-cannot-review') return 'is-not-approved';
    if (status === 'approved-minor-changes' || status === 'approved-after-these-changes') return 'is-approved-after-changes';
    return 'is-needs-review';
  }

  function screenSizeLabel(size) {
    const labels = {
      desktop: 'Desktop',
      'laptop-15-6': '15.6 display',
      'laptop-14-5': '14.5 display',
      'laptop-13': '13 display',
      mobile: 'Mobile'
    };

    return labels[size] || size || 'Not specified';
  }
%>

<section class="public-notes" aria-label="Visible review notes">
  <h4>Notes so far</h4>

  <% if (visibleNotes.length) { %>
    <ol class="public-notes__list">
      <% visibleNotes.forEach(note => { %>
        <li class="public-note <%= statusClass(note.status) %>">
          <span class="public-note__icon" aria-hidden="true"><%= statusIcon(note.status) %></span>

          <div class="public-note__body">
            <div class="public-note__meta">
              <strong><%= note.reviewerName || note.initials || 'Reviewer' %></strong>
              <span><%= statusLabel(note.status) %></span>
              <span><%= screenSizeLabel(note.screenSize) %></span>
            </div>

            <% if (note.comment) { %>
              <p><%= note.comment %></p>
            <% } else { %>
              <p class="muted">No comment added.</p>
            <% } %>
          </div>
        </li>
      <% }) %>
    </ol>
  <% } else { %>
    <p class="muted public-notes__empty">Nothing here yet.</p>
  <% } %>
</section>
