<%
  const visibleNotes = responses.filter(response => {
    const samePage = response.pageId === page.pageId;
    const sameScreen = (screenSize || '') === (response.screenSize || '');
    return samePage && sameScreen;
  });

  function statusLabel(status) {
    const labels = {
      'approved': 'Approved',
      'approved-minor-changes': 'Approved after these changes',
      'approved-after-these-changes': 'Approved after these changes',
      'needs-changes': 'Needs changes',
      'needs-design-changes': 'Needs design changes',
      'needs-content-changes': 'Needs content changes',
      'needs-mobile-review': 'Needs mobile review',
      'blocked-cannot-review': 'Blocked / cannot review',
      'not-approved': 'Not approved'
    };

    return labels[status] || status || 'Review note';
  }

  function statusIcon(status) {
    if (status === 'approved') return '✓';
    if (status === 'not-approved' || status === 'blocked-cannot-review') return '×';
    if (status === 'approved-minor-changes' || status === 'approved-after-these-changes') return '↻';
    return '!';
  }

  function statusClass(status) {
    if (status === 'approved') return 'is-approved';
    if (status === 'not-approved' || status === 'blocked-cannot-review') return 'is-not-approved';
    if (status === 'approved-minor-changes' || status === 'approved-after-these-changes') return 'is-approved-after-changes';
    return 'is-needs-review';
  }

  function screenSizeLabel(size) {
    const labels = {
      desktop: 'Full desktop',
      'desktop-1440': '1440 desktop',
      'laptop-15-6': '15.6 display',
      'laptop-14-5': '14.5 display',
      'laptop-13': '13 display',
      mobile: 'Mobile'
    };

    return labels[size] || size || 'Not specified';
  }

  const editableStatuses = [
    'approved',
    'approved-after-these-changes',
    'needs-changes',
    'blocked-cannot-review'
  ];
%>

<section class="public-notes" aria-label="Visible review notes">
  <h4>Notes so far</h4>

  <% if (visibleNotes.length) { %>
    <ol class="public-notes__list">
      <% visibleNotes.forEach(note => { %>
        <li class="public-note <%= statusClass(note.status) %>" data-note-id="<%= note.responseId %>">
          <span class="public-note__icon" aria-hidden="true"><%= statusIcon(note.status) %></span>

          <div class="public-note__body">
            <div class="public-note__meta">
              <strong><%= note.reviewerName || note.initials || 'Reviewer' %></strong>
              <span><%= statusLabel(note.status) %></span>
              <span><%= screenSizeLabel(note.screenSize) %></span>
            </div>

            <% if (note.comment) { %>
              <p><%= note.comment %></p>
            <% } else { %>
              <p class="muted">No comment added.</p>
            <% } %>

            <% if (note.canManage) { %>
            <details class="note-editor" data-note-editor data-note-id="<%= note.responseId %>">
              <summary>Edit selected pin</summary>

              <form method="post" action="/r/<%= packet.shareToken %>/feedback/<%= note.responseId %>/update">
                <% if (typeof adminKeyValue !== 'undefined' && adminKeyValue) { %>
                  <input type="hidden" name="key" value="<%= adminKeyValue %>">
                <% } %>

                <label>
                  Reviewer name or initials
                  <input type="text" name="reviewerName" maxlength="60" value="<%= note.reviewerName || note.initials || '' %>" required>
                </label>

                <label>
                  Status
                  <select name="status">
                    <% editableStatuses.forEach(status => { %>
                      <option value="<%= status %>" <%= note.status === status ? 'selected' : '' %>><%= statusLabel(status) %></option>
                    <% }) %>
                  </select>
                </label>

                <label>
                  Comment
                  <textarea name="comment"><%= note.comment || '' %></textarea>
                </label>

                <% if (note.dotX && note.dotY) { %>
                  <label class="remove-toggle">
                    <input type="checkbox" name="removeDot" value="true"> Remove pinned spot
                  </label>
                <% } %>

                <div class="note-editor__actions">
                  <button type="submit">Save changes</button>
                  <% if (note.dotX && note.dotY) { %>
                    <button type="button" class="button ghost" data-move-pin>Move pin</button>
                  <% } %>
                  <button type="submit" form="delete-note-<%= note.responseId %>" class="button danger">Delete note</button>
                  <button type="button" class="button ghost" data-cancel-edit>Cancel</button>
                </div>
              </form>

              <form id="delete-note-<%= note.responseId %>" method="post" action="/r/<%= packet.shareToken %>/feedback/<%= note.responseId %>/delete" onsubmit="return confirm('Delete this review note? This cannot be undone.');" hidden>
                <% if (typeof adminKeyValue !== 'undefined' && adminKeyValue) { %>
                  <input type="hidden" name="key" value="<%= adminKeyValue %>">
                <% } %>
              </form>
            </details>
            <% } %>
          </div>
        </li>
      <% }) %>
    </ol>
  <% } else { %>
    <p class="muted public-notes__empty">Nothing here yet.</p>
  <% } %>
</section>
