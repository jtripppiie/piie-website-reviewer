<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%23122333'/%3E%3Cpath d='M18 20h28v8H18zm0 16h18v8H18z' fill='%23ffffff'/%3E%3C/svg%3E">
  <link rel="stylesheet" href="/public/css/styles.css">
  <style>
    .app-version-badge {
      position: fixed;
      bottom: 8px;
      right: 10px;
      z-index: 9999;
      padding: 3px 8px;
      border-radius: 999px;
      background: #111827;
      color: #fff;
      font: 700 11px system-ui, sans-serif;
      letter-spacing: .03em;
      opacity: .75;
      pointer-events: none;
    }
  </style>
  <script>
    window.__APP_VERSION__ = <%- JSON.stringify(typeof appVersion !== 'undefined' ? appVersion : '') %>;
    document.addEventListener('DOMContentLoaded', function () {
      if (!window.__APP_VERSION__) return;
      var badge = document.createElement('div');
      badge.className = 'app-version-badge';
      badge.textContent = 'PIIE Reviewer v' + window.__APP_VERSION__;
      document.body.appendChild(badge);
    });
  </script>
</head>
