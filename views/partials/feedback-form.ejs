<form class="feedback" method="post" action="/r/<%= packet.shareToken %>/feedback">
  <input type="hidden" name="pageId" value="<%= page.pageId %>">
  <input type="hidden" name="screenSize" value="<%= screenSize %>">
  <input type="hidden" name="dotX" value="">
  <input type="hidden" name="dotY" value="">
  <% if (typeof adminKeyValue !== 'undefined' && adminKeyValue) { %>
    <input type="hidden" name="key" value="<%= adminKeyValue %>">
  <% } %>

  <div class="feedback-grid">
    <label>
      Reviewer name or initials
      <input type="text" name="reviewerName" maxlength="60" required>
    </label>

    <label>
      Status
      <select name="status">
        <option value="approved">Approved</option>
        <option value="approved-after-these-changes">Approved after these changes</option>
        <option value="needs-changes">Needs changes</option>
        <option value="blocked-cannot-review">Blocked</option>
      </select>
    </label>
  </div>

  <label>
    Comment
    <textarea name="comment"></textarea>
  </label>

  <p class="dot-location" data-dot-location hidden></p>

  <div class="feedback-actions">
    <button type="button" class="secondary" data-start-dot>Mark a spot</button>
    <button type="button" class="secondary" data-clear-dot hidden>Clear spot</button>
    <button type="submit">Save note</button>
  </div>
</form>
