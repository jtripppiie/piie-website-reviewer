<!doctype html>
<html lang="en">
  <%- include('partials/head', { title: 'Results' }) %>
  <body>
    <main class="shell">
      <p><a href="/admin/packets/<%= packet.packetId %>/edit?key=<%= key %>">Back to packet</a></p>

      <h1>Results: <%= packet.title %></h1>

      <p>
        <a class="button" href="/admin/packets/<%= packet.packetId %>/export.json?key=<%= key %>">Export JSON</a>
      </p>

      <% packet.pages.forEach(page => { %>
        <% const pageResponses = responses.filter(response => response.pageId === page.pageId); %>

        <section class="card">
          <p class="eyebrow"><%= page.type %></p>
          <h2><%= page.title %></h2>

          <% if (pageResponses.length) { %>
            <div class="stack">
              <% pageResponses.forEach((response, index) => { %>
                <article class="result-item">
                  <p class="eyebrow">Feedback <%= index + 1 %> · <%= response.createdAt %></p>
                  <p><strong>Reviewer:</strong> <%= response.reviewerName || response.initials || 'Unknown' %></p>
                  <% if (response.screenSize) { %>
                    <p><strong>Screen size:</strong> <%= response.screenSize %></p>
                  <% } %>
                  <p><strong>Status:</strong> <%= response.status %></p>
                  <% if (response.dotX && response.dotY) { %>
                    <p><strong>Dot:</strong> <%= response.dotX %>%, <%= response.dotY %>%</p>
                  <% } %>
                  <p><strong>Comment:</strong> <%= response.comment || 'No comment' %></p>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <p>No feedback for this page yet.</p>
          <% } %>
        </section>
      <% }) %>
    </main>
  </body>
</html>
