<!doctype html>
<html lang="en">
  <%- include('partials/head', { title: 'Admin Dashboard' }) %>
  <body>
    <main class="shell">
      <h1>Design Review Packets</h1>

      <form class="card" method="post" action="/admin/packets">
        <input type="hidden" name="key" value="<%= key %>">

        <label>
          New packet title
          <input type="text" name="title" placeholder="Example: Key Takeaways Design Review" required>
        </label>

        <button type="submit">Create Packet</button>
      </form>

      <form class="card" method="post" action="/admin/packets/demo">
        <input type="hidden" name="key" value="<%= key %>">

        <label>
          Test packet title
          <input type="text" name="title" placeholder="Example: Demo Review Packet">
        </label>

        <p class="muted">Creates a published packet with a cover page, generic photo comparison, two local demo web pages, and seeded notes so you can test review, notes, filters, and clear actions immediately.</p>

        <button type="submit">Create Test Packet</button>
      </form>

      <section class="stack">
        <% packets.forEach(packet => { %>
          <article class="card">
            <h2><%= packet.title %></h2>
            <p>Status: <strong><%= packet.published ? 'Published' : 'Draft' %></strong></p>
            <p>Pages: <%= packet.pages.length %></p>

            <div class="actions">
              <a class="button" href="/admin/packets/<%= packet.packetId %>/edit?key=<%= key %>">Edit</a>
              <a class="button" href="/admin/packets/<%= packet.packetId %>/results?key=<%= key %>">Results</a>
              <% if (packet.published) { %>
                <a class="button" href="/r/<%= packet.shareToken %>?key=<%= key %>">Review Link</a>
              <% } %>
              <form method="post" action="/admin/packets/<%= packet.packetId %>/clear-results" onsubmit="return confirm('Clear all review results for this packet? This cannot be undone.');">
                <input type="hidden" name="key" value="<%= key %>">
                <button type="submit" class="button danger">Clear review results</button>
              </form>
              <form method="post" action="/admin/packets/<%= packet.packetId %>/delete" onsubmit="return confirm('Delete this project and all of its review data? This cannot be undone.');">
                <input type="hidden" name="key" value="<%= key %>">
                <button type="submit" class="button danger">Delete project</button>
              </form>
            </div>
          </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>
