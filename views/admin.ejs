<!doctype html>
<html lang="en">
  <%- include('partials/head', { title: 'Admin Dashboard' }) %>
  <body class="admin-body">
    <main class="shell">
      <header class="admin-hero">
        <div>
          <p class="eyebrow">Internal review console</p>
          <h1>Design Review Packets</h1>
        </div>
        <a class="button secondary" href="https://jtripppiie.github.io/piie-website-reviewer/" target="_blank" rel="noopener">Live demo</a>
      </header>

      <form class="card admin-primary-card" method="post" action="/admin/packets" data-auto-capture-form>
        <input type="hidden" name="key" value="<%= key %>">
        <p class="eyebrow">New review</p>
        <h2>Start with Dev vs Live</h2>

        <label>
          Packet title
          <input type="text" name="title" placeholder="Example: Key Takeaways Design Review" required>
        </label>

        <label>
          Page title
          <input type="text" name="pageTitle" placeholder="Example: Homepage review" value="Dev vs Live review">
        </label>

        <label>
          Instructions
          <textarea name="instructions" placeholder="Example: Check hero spacing, navigation behavior, and mobile layout."></textarea>
        </label>

        <div class="admin-url-grid">
          <label>
            Dev URL
            <input type="text" name="devUrl" inputmode="url" list="review-url-options" value="https://www.nelsonstructural.com/" placeholder="https://dev.example.com or /public/demo/dev-home.html">
          </label>
          <label>
            Live URL
            <input type="text" name="liveUrl" inputmode="url" list="review-url-options" value="https://www.nelsonstructural.com/" placeholder="https://www.example.com or /public/demo/live-home.html">
          </label>
        </div>
        <datalist id="review-url-options">
          <option value="https://www.nelsonstructural.com/" label="Default demo - Nelson Structural">
          <option value="/public/demo/dev-home.html" label="Local test - Dev">
          <option value="/public/demo/live-home.html" label="Local test - Live">
          <option value="https://jtripppiie.github.io/piie-website-reviewer/demo-dev.html" label="Controlled demo - Dev">
          <option value="https://jtripppiie.github.io/piie-website-reviewer/demo-live.html" label="Controlled demo - Live">
        </datalist>

        <label class="capture-choice">
          <span>
            <input type="checkbox" name="autoCapture" value="true" checked data-auto-capture-toggle>
            Capture screenshots automatically
          </span>
          <small>Captures Desktop and Mobile from both URLs. This may take up to a minute.</small>
        </label>

        <details class="advanced-tools capture-options">
          <summary>Screenshot sizes</summary>
          <label class="radio-choice">
            <input type="radio" name="captureMode" value="primary" checked>
            Desktop and Mobile
          </label>
          <label class="radio-choice">
            <input type="radio" name="captureMode" value="all">
            All six screen sizes
          </label>
        </details>

        <p class="capture-submit-status" data-capture-status aria-live="polite" hidden>
          Capturing Dev and Live screenshots. Please keep this page open…
        </p>
        <button type="submit" data-create-review-button>Create review packet</button>
      </form>

      <script>
        (() => {
          const form = document.querySelector('[data-auto-capture-form]');
          if (!form) return;

          form.addEventListener('submit', () => {
            const shouldCapture = form.querySelector('[data-auto-capture-toggle]')?.checked;
            if (!shouldCapture) return;

            const button = form.querySelector('[data-create-review-button]');
            const status = form.querySelector('[data-capture-status]');
            if (button) {
              button.disabled = true;
              button.textContent = 'Capturing screenshots…';
            }
            if (status) status.hidden = false;
          });
        })();
      </script>

      <details class="card admin-secondary-tools">
        <summary>Testing and fallbacks</summary>
        <form method="post" action="/admin/packets/demo">
          <input type="hidden" name="key" value="<%= key %>">

          <label>
            Test packet title
            <input type="text" name="title" placeholder="Example: Demo Review Packet">
          </label>

          <p class="muted">Creates a published testing-mode packet with local Dev and Live demo pages, screenshot examples, and seeded notes for dry runs.</p>

          <button type="submit">Create local test packet</button>
        </form>
      </details>

      <section class="stack packet-list">
        <% packets.forEach(packet => { %>
          <article class="card packet-card">
            <div>
              <p class="eyebrow">Packet</p>
              <h2><%= packet.title %></h2>
              <div class="packet-meta">
                <span class="status-pill <%= packet.published ? 'is-open' : 'is-draft' %>"><%= packet.published ? 'Open for review' : 'Draft' %></span>
                <span><%= packet.pages.length %> <%= packet.pages.length === 1 ? 'page' : 'pages' %></span>
              </div>
            </div>

            <div class="actions">
              <a class="button" href="/admin/packets/<%= packet.packetId %>/edit?key=<%= key %>">Edit</a>
              <a class="button" href="/r/<%= packet.shareToken %>/notes?key=<%= key %>">Manage notes</a>
              <% if (packet.published) { %>
                <a class="button" href="/r/<%= packet.shareToken %>?key=<%= key %>">Review Link</a>
              <% } %>
              <form method="post" action="/admin/packets/<%= packet.packetId %>/start-round" onsubmit="return confirm('Start a new review round by deleting all notes for this packet? This cannot be undone.');">
                <input type="hidden" name="key" value="<%= key %>">
                <button type="submit" class="button danger">Start new round</button>
              </form>
              <form method="post" action="/admin/packets/<%= packet.packetId %>/delete" onsubmit="return confirm('Delete this project and all of its review data? This cannot be undone.');">
                <input type="hidden" name="key" value="<%= key %>">
                <button type="submit" class="button danger">Delete project</button>
              </form>
            </div>
          </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>
