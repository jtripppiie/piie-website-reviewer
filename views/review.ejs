<!doctype html>
<html lang="en">
  <%- include('partials/head', { title: packet.title }) %>
  <body class="review-body">
    <main class="review-deck">
      <%
        function screenSizeLabel(size) {
          const labels = {
            desktop: 'Desktop',
            'laptop-15-6': '15.6 display',
            'laptop-14-5': '14.5 display',
            'laptop-13': '13 display',
            mobile: 'Mobile'
          };

          return labels[size] || size;
        }
      %>
      <% packet.pages.forEach((page, index) => { %>
        <% const pageDots = responses.filter(response => response.pageId === page.pageId && response.dotX && response.dotY); %>

        <% if (page.type === 'cover') { %>
          <section class="review-page cover-slide" id="<%= page.pageId %>" data-page-title="<%= page.title %>">
            <p class="eyebrow">Page <%= index + 1 %></p>
            <h1><%= page.title %></h1>
            <% if (page.subtitle) { %><h2><%= page.subtitle %></h2><% } %>
            <% if (page.body) { %><p><%= page.body %></p><% } %>
          </section>
        <% } %>

        <% if (page.type === 'imageCompare') { %>
          <section class="review-page review-page--work" id="<%= page.pageId %>" data-page-title="<%= page.title %>">
            <div class="review-workspace">
              <div class="review-canvas">
                <div class="page-heading">
                  <p class="eyebrow">Page <%= index + 1 %></p>
                  <h2><%= page.title %></h2>
                  <% if (page.instructions) { %><p><%= page.instructions %></p><% } %>
                </div>

                <div class="compare wide-compare" data-compare data-annotatable>
                  <img class="before" src="<%= page.beforeImagePath %>" alt="<%= page.beforeLabel || 'Before' %>">
                  <img class="after" src="<%= page.afterImagePath %>" alt="<%= page.afterLabel || 'After' %>">
                  <span class="badge before-label"><%= page.beforeLabel || 'Before' %></span>
                  <span class="badge after-label"><%= page.afterLabel || 'After' %></span>
                  <div class="divider"></div>
                  <button class="handle" type="button" aria-label="Drag comparison handle"></button>

                  <% pageDots.forEach((dot, dotIndex) => { %>
                    <button
                      class="comment-dot"
                      type="button"
                      style="left: <%= dot.dotX %>%; top: <%= dot.dotY %>%"
                      title="<%= (dot.reviewerName || dot.initials || 'Reviewer') + ': ' + dot.status + (dot.comment ? ' - ' + dot.comment : '') %>">
                      <%= dotIndex + 1 %>
                    </button>
                  <% }) %>
                </div>

                <p class="muted">For best results, upload before and after screenshots with the same dimensions.</p>
              </div>

              <aside class="feedback-panel">
                <h3>Review Notes</h3>
                <p class="muted">Use the dot button if your comment refers to a specific part of the design.</p>
                <%- include('partials/public-notes', { responses, page, screenSize: '' }) %>
                <%- include('partials/feedback-form', { packet, page, screenSize: '' }) %>
              </aside>
            </div>
          </section>
        <% } %>

        <% if (page.type === 'urlCompare') { %>
          <section class="review-page review-page--work" id="<%= page.pageId %>" data-page-title="<%= page.title %>">
            <div class="review-workspace">
              <div class="review-canvas">
                <div class="page-heading">
                  <p class="eyebrow">Page <%= index + 1 %></p>
                  <h2><%= page.title %></h2>
                  <% if (page.instructions) { %><p><%= page.instructions %></p><% } %>
                </div>

                <div class="url-note">
                  <p>Some Dev/Test/Live sites block embedded previews for security reasons. Open each URL in a new tab, then review the uploaded screenshots below.</p>
                  <div class="actions">
                    <% if (page.devUrl) { %>
                      <a class="button" href="<%= page.devUrl %>" target="_blank" rel="noopener">Open Dev in new tab</a>
                    <% } %>
                    <% if (page.liveUrl) { %>
                      <a class="button" href="<%= page.liveUrl %>" target="_blank" rel="noopener">Open Live in new tab</a>
                    <% } %>
                  </div>
                </div>

                <div class="screen-tabs" data-url-tabs>
                  <% page.screenSizes.filter(size => size !== "tablet").forEach((size, sizeIndex) => { %>
                    <button type="button" class="<%= sizeIndex === 0 ? 'active' : '' %>" data-size="<%= size %>"><%= screenSizeLabel(size) %></button>
                  <% }) %>
                </div>

                <p class="viewport-note">
                  These previews are set to the selected target viewport size. Browser zoom, Windows display scaling, or monitor size may make the preview appear larger or smaller on your screen, but the review is still based on the selected viewport specification.
                </p>

                <% if (page.devScreenshotPath && page.liveScreenshotPath) { %>
                  <div class="compare wide-compare" data-compare data-annotatable>
                    <img class="before" src="<%= page.liveScreenshotPath %>" alt="Live screenshot">
                    <img class="after" src="<%= page.devScreenshotPath %>" alt="Dev screenshot">
                    <span class="badge before-label">Live</span>
                    <span class="badge after-label">Dev</span>
                    <div class="divider"></div>
                    <button class="handle" type="button" aria-label="Drag comparison handle"></button>

                    <% pageDots.forEach((dot, dotIndex) => { %>
                      <button
                        class="comment-dot"
                        type="button"
                        style="left: <%= dot.dotX %>%; top: <%= dot.dotY %>%"
                        title="<%= (dot.reviewerName || dot.initials || 'Reviewer') + ': ' + dot.status + (dot.comment ? ' - ' + dot.comment : '') %>">
                        <%= dotIndex + 1 %>
                      </button>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="webpage-preview-stage" data-webpage-preview>
                    <div class="webpage-frame-card">
                      <div class="webpage-frame-card__header">
                        <strong>Dev preview</strong>
                        <% if (page.devUrl) { %>
                          <a href="<%= page.devUrl %>" target="_blank" rel="noopener">Open Dev</a>
                        <% } %>
                      </div>

                      <% if (page.devUrl) { %>
                        <iframe src="<%= page.devUrl %>" title="Dev webpage preview"></iframe>
                      <% } else { %>
                        <div class="webpage-frame-empty">No Dev URL entered.</div>
                      <% } %>
                    </div>

                    <div class="webpage-frame-card">
                      <div class="webpage-frame-card__header">
                        <strong>Live preview</strong>
                        <% if (page.liveUrl) { %>
                          <a href="<%= page.liveUrl %>" target="_blank" rel="noopener">Open Live</a>
                        <% } %>
                      </div>

                      <% if (page.liveUrl) { %>
                        <iframe src="<%= page.liveUrl %>" title="Live webpage preview"></iframe>
                      <% } else { %>
                        <div class="webpage-frame-empty">No Live URL entered.</div>
                      <% } %>
                    </div>
                  </div>

                  <p class="muted">If a preview does not load, the site is blocking iframe embedding. Use the Open Dev / Open Live links instead, or upload screenshots from the admin page.</p>
                <% } %>
              </div>

              <aside class="feedback-panel">
                <h3>Screen-size Review Notes</h3>
                <p class="muted">Select a screen size, then save feedback for that specific size.</p>

                <% page.screenSizes.filter(size => size !== "tablet").forEach((size, sizeIndex) => { %>
                  <div class="screen-feedback <%= sizeIndex === 0 ? 'active' : '' %>" data-feedback-size="<%= size %>">
                    <h4><%= screenSizeLabel(size) %></h4>
                    <%- include('partials/public-notes', { responses, page, screenSize: size }) %>
                    <%- include('partials/feedback-form', { packet, page, screenSize: size }) %>
                  </div>
                <% }) %>
              </aside>
            </div>
          </section>
        <% } %>
      <% }) %>
    </main>

    <script src="/public/js/review.js"></script>
    <script src="/public/js/debug-layout.js"></script>
      <script src="/public/js/force-preview-layout.js"></script>
  </body>
</html>
