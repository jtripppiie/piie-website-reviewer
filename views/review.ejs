<!doctype html>
<html lang="en">
  <%- include('partials/head', { title: packet.title }) %>
  <body class="review-body">
    <header class="review-topbar">
      <div class="review-topbar__left">
        <div class="review-brand" title="Triple-click to toggle quick edit">
          <span class="review-brand__logo">
            <img src="/public/assets/logo.png?v=<%= appVersion %>" alt="PIIE Web Reviewer" onerror="this.hidden=true">
            <span class="review-brand__fallback">PIIE</span>
          </span>
        </div>
        <a class="button" href="/r/<%= packet.shareToken %>/notes<%= adminKeyValue ? '?key=' + adminKeyValue : '' %>"><%= isAdminView ? 'Manage notes' : 'View all notes' %></a>
        <button type="button" class="button" data-clear-local-notes data-clear-mine-url="/r/<%= packet.shareToken %>/clear-mine<%= adminKeyValue ? '?key=' + encodeURIComponent(adminKeyValue) : '' %>">Clear My Notes</button>
        <% if (isAdminView) { %>
          <button type="button" class="button danger quick-edit-only" data-clear-all-notes data-clear-all-url="/r/<%= packet.shareToken %>/clear-all?key=<%= encodeURIComponent(adminKeyValue) %>">Clear All Notes (admin)</button>
        <% } %>
        <div class="preview-status header-preview-status" data-header-preview-status aria-live="polite"></div>
      </div>
      <div class="review-nav">
      </div>
    </header>
    <main class="review-deck">
      <%
        function screenSizeLabel(size) {
          const labels = {
            desktop: 'Full desktop',
            'laptop-15-6': '15.6 display',
            'laptop-14-5': '14.5 display',
            'laptop-13': '13 display',
            mobile: 'Mobile'
          };

          return labels[size] || size;
        }

        const defaultScreenSizes = ['desktop', 'laptop-15-6', 'laptop-14-5', 'laptop-13', 'mobile'];
        function normalizedScreenSizes(sizes) {
          const result = [];
          const source = Array.isArray(sizes) && sizes.length ? sizes : defaultScreenSizes;
          source.filter(size => size !== 'tablet' && size !== 'desktop-1440').forEach(size => {
            if (!result.includes(size)) result.push(size);
          });
          defaultScreenSizes.forEach(size => {
            if (!result.includes(size)) result.push(size);
          });
          return result;
        }
        function highlightStyle(highlight) {
          const x = Number.parseFloat(highlight.x) || 0;
          const y = Number.parseFloat(highlight.y) || 0;
          const width = Number.parseFloat(highlight.width) || 12;
          const height = Number.parseFloat(highlight.height) || 8;
          return `left: ${x}%; top: ${y}%; width: ${width}%; height: ${height}%;`;
        }
        const preferredUrlPages = packet.pages.filter(page =>
          page.type === 'urlCompare' &&
          (page.devUrl || page.liveUrl || page.devShots || page.liveShots || page.devScreenshotPath || page.liveScreenshotPath)
        );
        const renderedPages = preferredUrlPages.length ? preferredUrlPages : packet.pages;
        const visiblePageCount = renderedPages.length;
      %>
      <% renderedPages.forEach((page, index) => { %>
        <% if (page.type === 'cover') { %>
          <section class="review-page cover-slide" id="<%= page.pageId %>" data-page-title="<%= page.title %>">
            <% if (isAdminView) { %>
              <div class="admin-edit-bar">
                <span class="admin-tag">Admin only</span>
                <a class="button" href="/admin/packets/<%= packet.packetId %>/edit?key=<%= adminKeyValue %>#page-<%= page.pageId %>">Edit this page</a>
              </div>
            <% } %>
            <h1><%= page.title %></h1>
            <% if (page.subtitle) { %><h2><%= page.subtitle %></h2><% } %>
            <% if (page.body) { %><p><%= page.body %></p><% } %>
            <p class="muted cover-count"><%= visiblePageCount %> <%= visiblePageCount === 1 ? 'page' : 'pages' %> &middot; <%= responses.length %> <%= responses.length === 1 ? 'note' : 'notes' %> so far</p>
            <p class="cover-notes-link">
              <a class="button" href="/r/<%= packet.shareToken %>/notes<%= adminKeyValue ? '?key=' + adminKeyValue : '' %>">View all notes</a>
            </p>
          </section>
        <% } %>

        <% if (page.type === 'imageCompare') { %>
          <section class="review-page review-page--work" id="<%= page.pageId %>" data-page-title="<%= page.title %>">
            <div class="review-workspace">
              <div class="review-canvas">
                <% if (isAdminView) { %>
                  <div class="admin-edit-bar">
                    <span class="admin-tag">Admin only</span>
                    <a class="button" href="/admin/packets/<%= packet.packetId %>/edit?key=<%= adminKeyValue %>#page-<%= page.pageId %>">Edit this page</a>
                  </div>
                <% } %>
                <div class="review-controls">
                  <span class="review-control-label">Screen size</span>
                  <nav class="screen-tabs screen-size-tabs" data-url-tabs aria-label="Screen size">
                    <% defaultScreenSizes.forEach((size, sizeIndex) => { %>
                      <button type="button" class="<%= sizeIndex === 0 ? 'active' : '' %>" data-size="<%= size %>"><%= screenSizeLabel(size) %></button>
                    <% }) %>
                  </nav>
                </div>

                <% if (canQuickEdit) { %>
                  <div class="quick-edit" data-quick-edit>
                    <div class="quick-edit__head">Quick edit</div>
                    <form class="quick-edit__form" method="post" action="/r/<%= packet.shareToken %>/quick-update<%= adminKeyValue ? '?key=' + encodeURIComponent(adminKeyValue) : '' %>" enctype="multipart/form-data">
                      <input type="hidden" name="pageId" value="<%= page.pageId %>">
                      <input type="hidden" name="key" value="<%= adminKeyValue %>">
                      <div class="quick-edit__row">
                        <label>Before image
                          <input type="file" name="beforeImage" accept="image/*">
                        </label>
                        <label>After image
                          <input type="file" name="afterImage" accept="image/*">
                        </label>
                      </div>
                      <button type="submit">Save to this page</button>
                    </form>
                  </div>
                <% } %>

                <div class="shots-stage" data-shots-stage>
                  <% defaultScreenSizes.forEach((size, sizeIndex) => { %>
                    <% const beforeImage = (page.beforeShots && page.beforeShots[size]) || page.beforeImagePath; %>
                    <% const afterImage = (page.afterShots && page.afterShots[size]) || page.afterImagePath; %>
                    <% const sizeDots = responses.filter(response => response.pageId === page.pageId && response.screenSize === size && response.dotX && response.dotY); %>
                    <% const sizeHighlights = (page.highlights || []).filter(highlight => !highlight.screenSize || highlight.screenSize === size); %>
                    <div class="shots-size <%= sizeIndex === 0 ? 'active' : '' %>" data-shots-size="<%= size %>">
                      <% if (beforeImage && afterImage) { %>
                        <% if (size === 'mobile') { %>
                          <div class="shots-pair shots-pair--mobile-fixed">
                            <figure class="shot-card">
                              <figcaption><%= page.beforeLabel || 'Before' %></figcaption>
                              <img src="<%= beforeImage %>" alt="<%= page.beforeLabel || 'Before' %> at <%= screenSizeLabel(size) %>">
                            </figure>
                            <figure class="shot-card">
                              <figcaption><%= page.afterLabel || 'After' %></figcaption>
                              <img src="<%= afterImage %>" alt="<%= page.afterLabel || 'After' %> at <%= screenSizeLabel(size) %>">
                            </figure>
                          </div>
                          <p class="muted">View at 100%:
                            <% if (beforeImage) { %><a href="<%= beforeImage %>" target="_blank" rel="noopener"><%= page.beforeLabel || 'Before' %></a><% } %>
                            <% if (afterImage) { %><a href="<%= afterImage %>" target="_blank" rel="noopener"><%= page.afterLabel || 'After' %></a><% } %>
                          </p>
                        <% } else { %>
                          <div class="compare wide-compare" data-compare data-annotatable>
                            <img class="before" src="<%= beforeImage %>" alt="<%= page.beforeLabel || 'Before' %> at <%= screenSizeLabel(size) %>">
                            <img class="after" src="<%= afterImage %>" alt="<%= page.afterLabel || 'After' %> at <%= screenSizeLabel(size) %>">
                            <span class="badge before-label"><%= page.beforeLabel || 'Before' %></span>
                            <span class="badge after-label"><%= page.afterLabel || 'After' %></span>
                            <div class="divider"></div>
                            <button class="handle" type="button" aria-label="Drag comparison handle"></button>

                            <% sizeHighlights.forEach((highlight, highlightIndex) => { %>
                              <button
                                class="admin-highlight admin-highlight--<%= highlight.type || 'box' %> admin-highlight--<%= highlight.direction || 'right' %>"
                                type="button"
                                style="<%= highlightStyle(highlight) %>"
                                data-highlight-label="<%= highlight.label || '' %>"
                                aria-label="<%= highlight.label || `Admin highlight ${highlightIndex + 1}` %>">
                                <% if (highlight.label) { %><span><%= highlight.label %></span><% } %>
                              </button>
                            <% }) %>

                            <% sizeDots.forEach((dot, dotIndex) => { %>
                              <button
                                class="comment-dot"
                                type="button"
                                style="left: <%= dot.dotX %>%; top: <%= dot.dotY %>%"
                                title="<%= (dot.reviewerName || dot.initials || 'Reviewer') + ': ' + dot.status + (dot.comment ? ' - ' + dot.comment : '') %>"
                                data-reviewer="<%= dot.reviewerName || dot.initials || 'Reviewer' %>"
                                data-status="<%= dot.status || 'Review note' %>"
                                data-screen="<%= screenSizeLabel(dot.screenSize) %>"
                                data-comment="<%= dot.comment || '' %>"
                                data-note-id="<%= dot.responseId %>"
                                <% if (dot.canManage) { %>data-position-url="/r/<%= packet.shareToken %>/feedback/<%= dot.responseId %>/position<%= adminKeyValue ? '?key=' + encodeURIComponent(adminKeyValue) : '' %>"<% } %>>
                                <%= dotIndex + 1 %>
                              </button>
                            <% }) %>
                          </div>

                          <p class="muted">View at 100%:
                            <% if (beforeImage) { %><a href="<%= beforeImage %>" target="_blank" rel="noopener"><%= page.beforeLabel || 'Before' %></a><% } %>
                            <% if (afterImage) { %><a href="<%= afterImage %>" target="_blank" rel="noopener"><%= page.afterLabel || 'After' %></a><% } %>
                          </p>
                        <% } %>
                      <% } else { %>
                        <div class="shot-empty">No before/after images for <%= screenSizeLabel(size) %> yet.</div>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              </div>

              <div class="feedback-dock">
              <aside class="feedback-panel" data-feedback-panel>
                <div class="feedback-panel__bar">
                  <h3>Add Notes</h3>
                  <button type="button" class="feedback-panel__toggle" data-feedback-toggle aria-expanded="true" aria-label="Collapse notes">Collapse</button>
                </div>
                <p class="muted">Pick a screen size, then leave your notes for it.</p>

                <% defaultScreenSizes.forEach((size, sizeIndex) => { %>
                  <div class="screen-feedback <%= sizeIndex === 0 ? 'active' : '' %>" data-feedback-size="<%= size %>">
                    <h4><%= screenSizeLabel(size) %></h4>
                    <%- include('partials/public-notes', { responses, page, screenSize: size }) %>
                    <%- include('partials/feedback-form', { packet, page, screenSize: size }) %>
                    <% if (isAdminView) { %>
                      <form class="clear-notes-form" method="post" action="/r/<%= packet.shareToken %>/clear-notes?key=<%= adminKeyValue %>" onsubmit="return confirm('Delete notes for this page and screen size? This cannot be undone.');">
                        <input type="hidden" name="key" value="<%= adminKeyValue %>">
                        <input type="hidden" name="pageId" value="<%= page.pageId %>">
                        <input type="hidden" name="screenSize" value="<%= size %>">
                        <button type="submit">Delete notes for <%= screenSizeLabel(size) %> (admin only)</button>
                      </form>
                    <% } %>
                  </div>
                <% }) %>
              </aside>
              </div>
            </div>
          </section>
        <% } %>

        <% if (page.type === 'urlCompare') { %>
          <section class="review-page review-page--work" id="<%= page.pageId %>" data-page-title="<%= page.title %>">
            <div class="review-workspace">
              <div class="review-canvas">
                <% if (isAdminView) { %>
                  <div class="admin-edit-bar">
                    <span class="admin-tag">Admin only</span>
                    <a class="button" href="/admin/packets/<%= packet.packetId %>/edit?key=<%= adminKeyValue %>#page-<%= page.pageId %>">Edit this page</a>
                  </div>
                <% } %>
                <% if (canQuickEdit) { %>
                  <div class="quick-edit" data-quick-edit>
                    <div class="quick-edit__head">Quick edit</div>
                    <form class="quick-edit__form" method="post" action="/r/<%= packet.shareToken %>/quick-update<%= adminKeyValue ? '?key=' + encodeURIComponent(adminKeyValue) : '' %>" enctype="multipart/form-data">
                      <input type="hidden" name="pageId" value="<%= page.pageId %>">
                      <input type="hidden" name="key" value="<%= adminKeyValue %>">
                      <div class="quick-edit__row">
                        <label>Dev URL
                          <input type="text" name="devUrl" inputmode="url" value="<%= page.devUrl || '' %>" placeholder="https://dev.example.com or /public/demo/dev-home.html">
                        </label>
                        <label>Live URL
                          <input type="text" name="liveUrl" inputmode="url" value="<%= page.liveUrl || '' %>" placeholder="https://www.example.com or /public/demo/live-home.html">
                        </label>
                      </div>
                      <div class="quick-edit__row">
                        <label>Dev screenshot
                          <input type="file" name="devScreenshot" accept="image/*">
                        </label>
                        <label>Live screenshot
                          <input type="file" name="liveScreenshot" accept="image/*">
                        </label>
                      </div>
                      <button type="submit">Save to this page</button>
                    </form>
                  </div>
                <% } %>

                <div class="review-controls">
                  <span class="review-control-label">Screen size</span>
                  <nav class="screen-tabs screen-size-tabs" data-url-tabs aria-label="Screen size">
                    <% normalizedScreenSizes(page.screenSizes).forEach((size, sizeIndex) => { %>
                      <button type="button" class="<%= sizeIndex === 0 ? 'active' : '' %>" data-size="<%= size %>"><%= screenSizeLabel(size) %></button>
                    <% }) %>
                  </nav>
                  <% if (page.devUrl || page.liveUrl) { %>
                    <span class="review-control-label">Review mode</span>
                    <nav class="screen-tabs review-mode-tabs" data-webpage-modes aria-label="Review mode">
                      <button type="button" data-webpage-mode="interact" hidden disabled aria-hidden="true">Interact</button>
                      <button type="button" class="active" data-webpage-mode="compare" title="Stack Dev and Live together and drag the slider to compare visual differences." data-tooltip="Stack Dev and Live together and drag the slider to compare visual differences.">Compare</button>
                      <button type="button" data-webpage-mode="annotate">Annotate</button>
                      <button type="button" data-webpage-diff>Highlight differences</button>
                    </nav>
                  <% } %>
                </div>

                <% if (page.devUrl || page.liveUrl) { %>
                  <% const webpageDots = responses.filter(response => response.pageId === page.pageId && response.dotX && response.dotY); %>
                  <% const webpageHighlights = page.highlights || []; %>
                  <div class="webpage-preview-stage is-slider" data-webpage-preview data-webpage-compare>
                    <div class="webpage-frame-card webpage-frame-card--dev">
                      <div class="webpage-frame-card__header">
                        <strong>Dev preview</strong>
                        <% if (page.devUrl) { %>
                          <a href="<%= page.devUrl %>" target="_blank" rel="noopener">Open Dev</a>
                        <% } %>
                      </div>

                      <% if (page.devUrl) { %>
                        <iframe src="<%= page.devUrl %>" title="Dev webpage preview"></iframe>
                      <% } else { %>
                        <div class="webpage-frame-empty">No Dev URL entered.</div>
                      <% } %>
                    </div>

                    <div class="webpage-frame-card webpage-frame-card--live">
                      <div class="webpage-frame-card__header">
                        <strong>Live preview</strong>
                        <% if (page.liveUrl) { %>
                          <a href="<%= page.liveUrl %>" target="_blank" rel="noopener">Open Live</a>
                        <% } %>
                      </div>

                      <% if (page.liveUrl) { %>
                        <iframe src="<%= page.liveUrl %>" title="Live webpage preview"></iframe>
                      <% } else { %>
                        <div class="webpage-frame-empty">No Live URL entered.</div>
                      <% } %>
                    </div>

                    <span class="badge before-label webpage-slider-only">Dev</span>
                    <span class="badge after-label webpage-slider-only">Live</span>
                    <div class="divider webpage-slider-only"></div>
                    <button class="handle webpage-slider-only" type="button" aria-label="Drag website comparison handle"></button>

                    <% webpageHighlights.forEach((highlight, highlightIndex) => { %>
                      <button
                        class="admin-highlight admin-highlight--<%= highlight.type || 'box' %> admin-highlight--<%= highlight.direction || 'right' %>"
                        type="button"
                        style="<%= highlightStyle(highlight) %>"
                        data-highlight-screen="<%= highlight.screenSize || '' %>"
                        data-highlight-label="<%= highlight.label || '' %>"
                        aria-label="<%= highlight.label || `Admin highlight ${highlightIndex + 1}` %>">
                        <% if (highlight.label) { %><span><%= highlight.label %></span><% } %>
                      </button>
                    <% }) %>

                    <div class="webpage-annotation-overlay" data-annotation-overlay>
                      <% webpageDots.forEach((dot, dotIndex) => { %>
                        <button
                          class="comment-dot"
                          type="button"
                          style="left: <%= dot.dotX %>%; top: <%= dot.dotY %>%"
                          title="<%= (dot.reviewerName || dot.initials || 'Reviewer') + ': ' + dot.status + (dot.comment ? ' - ' + dot.comment : '') %>"
                          data-reviewer="<%= dot.reviewerName || dot.initials || 'Reviewer' %>"
                          data-status="<%= dot.status || 'Review note' %>"
                          data-screen="<%= screenSizeLabel(dot.screenSize) %>"
                          data-dot-screen="<%= dot.screenSize || '' %>"
                          data-comment="<%= dot.comment || '' %>"
                          data-note-id="<%= dot.responseId %>"
                          <% if (dot.canManage) { %>data-position-url="/r/<%= packet.shareToken %>/feedback/<%= dot.responseId %>/position<%= adminKeyValue ? '?key=' + encodeURIComponent(adminKeyValue) : '' %>"<% } %>>
                          <%= dotIndex + 1 %>
                        </button>
                      <% }) %>
                    </div>
                  </div>

                <% } else if (page.devShots || page.liveShots) { %>
                  <%
                    const shotSizes = normalizedScreenSizes(page.screenSizes);
                    const cssDims = {
                      desktop: 'available width x 900',
                      'desktop-1440': '1440 x 900',
                      'laptop-15-6': '1366 x 768',
                      'laptop-14-5': '1280 x 760',
                      'laptop-13': '1180 x 720',
                      mobile: '390 x 844'
                    };
                  %>
                  <div class="shots-stage" data-shots-stage>
                    <% shotSizes.forEach((size, shotIndex) => { %>
                      <div class="shots-size <%= shotIndex === 0 ? 'active' : '' %>" data-shots-size="<%= size %>">
                        <p class="shots-size__caption"><%= screenSizeLabel(size) %> (<%= cssDims[size] || '' %>), full page</p>
                        <div class="shots-pair shots-pair--<%= size === 'mobile' ? 'row' : 'col' %>">
                          <figure class="shot-card">
                            <figcaption>Dev: <%= screenSizeLabel(size) %></figcaption>
                            <% if (page.devShots && page.devShots[size]) { %>
                              <img src="<%= page.devShots[size] %>" alt="Dev screenshot at <%= screenSizeLabel(size) %>">
                              <a class="shot-fullsize" href="<%= page.devShots[size] %>" target="_blank" rel="noopener">View at 100%</a>
                            <% } else { %>
                              <div class="shot-empty">No Dev shot for this size yet.</div>
                            <% } %>
                          </figure>
                          <figure class="shot-card">
                            <figcaption>Live: <%= screenSizeLabel(size) %></figcaption>
                            <% if (page.liveShots && page.liveShots[size]) { %>
                              <img src="<%= page.liveShots[size] %>" alt="Live screenshot at <%= screenSizeLabel(size) %>">
                              <a class="shot-fullsize" href="<%= page.liveShots[size] %>" target="_blank" rel="noopener">View at 100%</a>
                            <% } else { %>
                              <div class="shot-empty">No Live shot for this size yet.</div>
                            <% } %>
                          </figure>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } else if (page.devScreenshotPath && page.liveScreenshotPath) { %>
                  <% const pageDots = responses.filter(response => response.pageId === page.pageId && response.dotX && response.dotY); %>
                  <% const pageHighlights = page.highlights || []; %>
                  <div class="compare wide-compare" data-compare data-annotatable>
                    <img class="before" src="<%= page.liveScreenshotPath %>" alt="Live screenshot">
                    <img class="after" src="<%= page.devScreenshotPath %>" alt="Dev screenshot">
                    <span class="badge before-label">Live</span>
                    <span class="badge after-label">Dev</span>
                    <div class="divider"></div>
                    <button class="handle" type="button" aria-label="Drag comparison handle"></button>

                    <% pageHighlights.forEach((highlight, highlightIndex) => { %>
                      <button
                        class="admin-highlight admin-highlight--<%= highlight.type || 'box' %> admin-highlight--<%= highlight.direction || 'right' %>"
                        type="button"
                        style="<%= highlightStyle(highlight) %>"
                        data-highlight-screen="<%= highlight.screenSize || '' %>"
                        data-highlight-label="<%= highlight.label || '' %>"
                        aria-label="<%= highlight.label || `Admin highlight ${highlightIndex + 1}` %>">
                        <% if (highlight.label) { %><span><%= highlight.label %></span><% } %>
                      </button>
                    <% }) %>

                    <% pageDots.forEach((dot, dotIndex) => { %>
                      <button
                        class="comment-dot"
                        type="button"
                        style="left: <%= dot.dotX %>%; top: <%= dot.dotY %>%"
                        title="<%= (dot.reviewerName || dot.initials || 'Reviewer') + ': ' + dot.status + (dot.comment ? ' - ' + dot.comment : '') %>"
                        data-reviewer="<%= dot.reviewerName || dot.initials || 'Reviewer' %>"
                        data-status="<%= dot.status || 'Review note' %>"
                        data-screen="<%= screenSizeLabel(dot.screenSize) %>"
                        data-comment="<%= dot.comment || '' %>"
                        data-note-id="<%= dot.responseId %>"
                        <% if (dot.canManage) { %>data-position-url="/r/<%= packet.shareToken %>/feedback/<%= dot.responseId %>/position<%= adminKeyValue ? '?key=' + encodeURIComponent(adminKeyValue) : '' %>"<% } %>>
                        <%= dotIndex + 1 %>
                      </button>
                    <% }) %>
                  </div>
                  <p class="muted">View at 100%:
                    <a href="<%= page.liveScreenshotPath %>" target="_blank" rel="noopener">Live</a>
                    <a href="<%= page.devScreenshotPath %>" target="_blank" rel="noopener">Dev</a>
                  </p>
                <% } else { %>
                  <div class="webpage-preview-stage" data-webpage-preview>
                    <div class="webpage-frame-card">
                      <div class="webpage-frame-card__header">
                        <strong>Dev preview</strong>
                      </div>
                      <div class="webpage-frame-empty">No Dev URL entered.</div>
                    </div>

                    <div class="webpage-frame-card">
                      <div class="webpage-frame-card__header">
                        <strong>Live preview</strong>
                      </div>
                      <div class="webpage-frame-empty">No Live URL entered.</div>
                    </div>
                  </div>

                  <p class="muted">Add Dev and Live URLs to preview the webpages here, or upload screenshots from the admin page.</p>
                <% } %>
              </div>

              <div class="feedback-dock">
              <aside class="feedback-panel" data-feedback-panel>
                <div class="feedback-panel__bar">
                  <h3>Add Notes</h3>
                  <button type="button" class="feedback-panel__toggle" data-feedback-toggle aria-expanded="true" aria-label="Collapse notes">Collapse</button>
                </div>
                <p class="muted">Pick a screen size, then leave your notes for it.</p>

                <% normalizedScreenSizes(page.screenSizes).forEach((size, sizeIndex) => { %>
                  <div class="screen-feedback <%= sizeIndex === 0 ? 'active' : '' %>" data-feedback-size="<%= size %>">
                    <h4><%= screenSizeLabel(size) %></h4>
                    <%- include('partials/public-notes', { responses, page, screenSize: size }) %>
                    <%- include('partials/feedback-form', { packet, page, screenSize: size }) %>
                    <% if (isAdminView) { %>
                      <form class="clear-notes-form" method="post" action="/r/<%= packet.shareToken %>/clear-notes?key=<%= adminKeyValue %>" onsubmit="return confirm('Delete notes for this page and screen size? This cannot be undone.');">
                        <input type="hidden" name="key" value="<%= adminKeyValue %>">
                        <input type="hidden" name="pageId" value="<%= page.pageId %>">
                        <input type="hidden" name="screenSize" value="<%= size %>">
                        <button type="submit">Delete notes for <%= screenSizeLabel(size) %> (admin only)</button>
                      </form>
                    <% } %>
                  </div>
                <% }) %>
              </aside>
              </div>
            </div>
          </section>
        <% } %>
      <% }) %>
    </main>

