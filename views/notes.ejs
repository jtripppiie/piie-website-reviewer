<!doctype html>
<html lang="en">
  <%- include('partials/head', { title: packet.title + ' - Notes' }) %>
  <body class="notes-body">
    <main class="notes-page">
      <header class="notes-header" data-notes-header data-admin-href="/admin<%= adminKeyValue ? '?key=' + adminKeyValue : '' %>">
        <div>
          <p class="eyebrow">Review notes</p>
          <h1><%= packet.title %></h1>
          <p class="muted"><%= responses.length %> <%= responses.length === 1 ? 'note' : 'notes' %> so far.</p>
        </div>
        <div class="notes-actions">
          <a class="button" href="/r/<%= packet.shareToken %><%= adminKeyValue ? '?key=' + adminKeyValue : '' %>">Back to review</a>
          <% if (responses.length) { %>
            <%
              const dlParams = [];
              if (filterPage) dlParams.push('page=' + encodeURIComponent(filterPage));
              if (filterStatus) dlParams.push('status=' + encodeURIComponent(filterStatus));
              const dlQuery = dlParams.length ? '?' + dlParams.join('&') : '';
            %>
            <a class="button primary" href="/r/<%= packet.shareToken %>/notes/download<%= dlQuery %>">Download notes</a>
          <% } %>
        </div>
      </header>

      <% const statusOptions = ['approved','approved-after-these-changes','needs-design-changes','needs-content-changes','needs-mobile-review','blocked-cannot-review','not-approved']; %>
      <form class="notes-filter" method="get" action="/r/<%= packet.shareToken %>/notes">
        <% if (adminKeyValue) { %><input type="hidden" name="key" value="<%= adminKeyValue %>"><% } %>
        <label>Page
          <select name="page">
            <option value="">All pages</option>
            <% packet.pages.forEach(p => { %>
              <option value="<%= p.pageId %>" <%= filterPage === p.pageId ? 'selected' : '' %>><%= p.title || 'Untitled page' %></option>
            <% }) %>
          </select>
        </label>
        <label>Status
          <select name="status">
            <option value="">All statuses</option>
            <% statusOptions.forEach(s => { %>
              <option value="<%= s %>" <%= filterStatus === s ? 'selected' : '' %>><%= humanStatus(s) %></option>
            <% }) %>
          </select>
        </label>
        <button type="submit">Apply</button>
        <% if (filterPage || filterStatus) { %>
          <a class="button" href="/r/<%= packet.shareToken %>/notes<%= adminKeyValue ? '?key=' + adminKeyValue : '' %>">Clear</a>
        <% } %>
      </form>

      <% if (!responses.length) { %>
        <p class="notes-empty">No notes have been left yet. Once reviewers save notes, they show up here.</p>
      <% } else { %>
        <% packet.pages.forEach(page => { %>
          <% const pageNotes = responses.filter(r => r.pageId === page.pageId); %>
          <% if (pageNotes.length) { %>
            <section class="notes-group">
              <h2><%= page.title || 'Untitled page' %></h2>
              <ol class="notes-cards">
                <% pageNotes.forEach(note => { %>
                  <li class="note-card">
                    <div class="note-card__top">
                      <strong><%= note.reviewerName || note.initials || 'Reviewer' %></strong>
                      <span class="note-pill"><%= humanStatus(note.status) %></span>
                      <span class="note-size"><%= humanScreenSize(note.screenSize) %></span>
                    </div>
                    <% if (note.comment) { %>
                      <p class="note-comment"><%= note.comment %></p>
                    <% } else { %>
                      <p class="note-comment muted">No comment.</p>
                    <% } %>
                    <p class="note-meta muted">
                      <% if (note.dotX && note.dotY) { %>Marked a spot &middot; <% } %>
                      <%= note.createdAt ? new Date(note.createdAt).toLocaleString() : '' %>
                    </p>
                  </li>
                <% }) %>
              </ol>
            </section>
          <% } %>
        <% }) %>
      <% } %>
    </main>

    <script>
      (function () {
        const header = document.querySelector('[data-notes-header]');
        if (!header) return;

        const adminHref = header.getAttribute('data-admin-href') || '/admin';
        let clicks = 0;
        let timer = null;

        header.addEventListener('click', event => {
          if (!event.target.closest('.eyebrow, h1, .muted')) return;

          clicks += 1;
          clearTimeout(timer);
          timer = setTimeout(() => {
            clicks = 0;
          }, 600);

          if (clicks >= 3) {
            clicks = 0;
            clearTimeout(timer);
            window.location.assign(adminHref);
          }
        });
      })();
    </script>
  </body>
</html>
