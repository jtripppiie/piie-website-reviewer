<!doctype html>
<html lang="en">
  <%- include('partials/head', { title: 'Edit Packet' }) %>
  <body class="admin-body edit-packet-page">
    <main class="shell">
      <header class="admin-hero">
        <div>
          <p class="eyebrow">Packet setup</p>
          <h1>Edit Packet</h1>
        </div>
        <a class="button secondary" href="/admin?key=<%= key %>">Back to admin</a>
      </header>

      <% if (captured) { %>
        <div class="admin-notice admin-notice--success" role="status">
          Desktop and Mobile screenshots were captured from the Dev and Live URLs.
        </div>
      <% } %>
      <% if (captureError) { %>
        <div class="admin-notice admin-notice--error" role="alert">
          The review was created, but automatic screenshots failed: <%= captureError %>
        </div>
      <% } %>

      <section class="card admin-simple-flow">
        <p class="eyebrow">1.0 workflow</p>
        <h2>One normal path</h2>
        <p>Create or edit a Dev vs Live page, publish the packet, then manage notes from the review link.</p>
        <p>Use screenshot fallbacks only when a site blocks embedding or capture is more reliable for review.</p>
      </section>

      <section class="card">
        <h2>Packet Details</h2>

        <form method="post" action="/admin/packets/<%= packet.packetId %>/update">
          <input type="hidden" name="key" value="<%= key %>">

          <label>
            Packet title
            <input type="text" name="title" value="<%= packet.title %>" required>
          </label>

          <button type="submit">Save Packet Details</button>
        </form>
      </section>

      <section class="card">
        <h2>Review Status</h2>
        <p>Status: <span class="status-pill <%= packet.published ? 'is-open' : 'is-draft' %>"><%= packet.published ? 'Open for review' : 'Draft' %></span></p>

        <form method="post" action="/admin/packets/<%= packet.packetId %>/publish">
          <input type="hidden" name="key" value="<%= key %>">
          <input type="hidden" name="published" value="<%= packet.published ? 'false' : 'true' %>">
          <button type="submit"><%= packet.published ? 'Close review' : 'Open for review' %></button>
        </form>

        <% if (packet.published) { %>
          <p>Review link: <a href="/r/<%= packet.shareToken %>?key=<%= key %>">/r/<%= packet.shareToken %></a></p>
        <% } else { %>
          <p class="muted">Open the review when it is ready for reviewers.</p>
        <% } %>
      </section>

      <h2>Add Review Work</h2>

      <section class="stack">
        <form class="card admin-primary-card" method="post" action="/admin/packets/<%= packet.packetId %>/url-compare?key=<%= encodeURIComponent(key) %>" enctype="multipart/form-data">
          <input type="hidden" name="key" value="<%= key %>">
          <p class="eyebrow">Primary</p>
          <h3>Add Dev vs Live page</h3>

          <label>Title <input type="text" name="title" required></label>
          <label>Instructions <textarea name="instructions"></textarea></label>
          <label>Dev URL <input type="text" name="devUrl" inputmode="url" list="review-url-options" value="https://www.nelsonstructural.com/" placeholder="https://dev-example.pantheonsite.io or /public/demo/dev-home.html"></label>
          <label>Live URL <input type="text" name="liveUrl" inputmode="url" list="review-url-options" value="https://www.nelsonstructural.com/" placeholder="https://www.example.com or /public/demo/live-home.html"></label>
          <datalist id="review-url-options">
            <option value="https://www.nelsonstructural.com/" label="Default demo - Nelson Structural">
            <option value="/public/demo/dev-home.html" label="Local test - Dev">
            <option value="/public/demo/live-home.html" label="Local test - Live">
            <option value="https://jtripppiie.github.io/piie-website-reviewer/demo-dev.html" label="Controlled demo - Dev">
            <option value="https://jtripppiie.github.io/piie-website-reviewer/demo-live.html" label="Controlled demo - Live">
          </datalist>

          <details class="advanced-tools">
            <summary>Preview fallback screenshots</summary>
            <p class="muted">Use these if embedded previews are blocked and you already have a Dev and Live screenshot.</p>
            <label>Dev screenshot <input type="file" name="devScreenshot" accept="image/*"></label>
            <label>Live screenshot <input type="file" name="liveScreenshot" accept="image/*"></label>
          </details>

          <button type="submit">Add Dev vs Live</button>
        </form>

        <details class="card admin-secondary-tools">
          <summary>Additional page types</summary>

          <div class="grid">
            <form class="admin-inline-tool" method="post" action="/admin/packets/<%= packet.packetId %>/cover">
              <input type="hidden" name="key" value="<%= key %>">
              <h3>Add Cover Page</h3>

              <label>Title <input type="text" name="title" required></label>
              <label>Subtitle <input type="text" name="subtitle"></label>
              <label>Body <textarea name="body"></textarea></label>

              <button type="submit">Add Cover</button>
            </form>

            <form class="admin-inline-tool" method="post" action="/admin/packets/<%= packet.packetId %>/image-compare?key=<%= encodeURIComponent(key) %>" enctype="multipart/form-data">
              <input type="hidden" name="key" value="<%= key %>">
              <h3>Add Image Comparison</h3>

              <label>Title <input type="text" name="title" required></label>
              <label>Instructions <textarea name="instructions"></textarea></label>
              <label>Before label <input type="text" name="beforeLabel" value="Before"></label>
              <label>After label <input type="text" name="afterLabel" value="After"></label>
              <label>Before image <input type="file" name="beforeImage" accept="image/*" required></label>
              <label>After image <input type="file" name="afterImage" accept="image/*" required></label>

              <button type="submit">Add Images</button>
            </form>
          </div>
        </details>
      </section>

      <h2>Edit Existing Pages</h2>

      <section class="stack">
        <% packet.pages.forEach((page, index) => { %>
          <article class="card" id="page-<%= page.pageId %>">
            <p class="eyebrow">Page <%= index + 1 %>: <%= page.type %></p>

            <form method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/update?key=<%= encodeURIComponent(key) %>" enctype="multipart/form-data">
              <input type="hidden" name="key" value="<%= key %>">

              <label>
                Title
                <input type="text" name="title" value="<%= page.title || '' %>" required>
              </label>

              <% if (page.type === 'cover') { %>
                <label>
                  Subtitle
                  <input type="text" name="subtitle" value="<%= page.subtitle || '' %>">
                </label>

                <label>
                  Body
                  <textarea name="body"><%= page.body || '' %></textarea>
                </label>
              <% } %>

              <% if (page.type === 'imageCompare') { %>
                <% const presetList = [['desktop','Full desktop'],['laptop-15-6','15.6 display'],['laptop-14-5','14.5 display'],['laptop-13','13 display'],['mobile','Mobile']]; %>
                <p class="muted">This page is one image comparison: one Before image and one After image.</p>
                <label>
                  Instructions
                  <textarea name="instructions"><%= page.instructions || '' %></textarea>
                </label>

                <label>
                  Before label
                  <input type="text" name="beforeLabel" value="<%= page.beforeLabel || 'Before' %>">
                </label>

                <label>
                  After label
                  <input type="text" name="afterLabel" value="<%= page.afterLabel || 'After' %>">
                </label>

                <p class="muted">Current before image: <%= page.beforeImagePath || 'None' %></p>
                <label>
                  Replace before image
                  <input type="file" name="beforeImage" accept="image/*">
                </label>
                <% if (page.beforeImagePath) { %>
                  <label class="remove-toggle">
                    <input type="checkbox" name="removeBeforeImage" value="true"> Remove before image
                  </label>
                <% } %>

                <p class="muted">Current after image: <%= page.afterImagePath || 'None' %></p>
                <label>
                  Replace after image
                  <input type="file" name="afterImage" accept="image/*">
                </label>
                <% if (page.afterImagePath) { %>
                  <label class="remove-toggle">
                    <input type="checkbox" name="removeAfterImage" value="true"> Remove after image
                  </label>
                <% } %>

                <details class="advanced-tools">
                  <summary>Optional per-size image uploads</summary>
                  <p class="muted">Upload separate Before and After images for Full desktop, laptop sizes, and Mobile only when you need size-specific assets.</p>
                  <form method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/upload-shots?key=<%= encodeURIComponent(key) %>" enctype="multipart/form-data">
                    <input type="hidden" name="key" value="<%= key %>">
                    <% presetList.forEach(([sizeKey, sizeLabel]) => { %>
                      <fieldset class="shot-upload">
                        <legend><%= sizeLabel %></legend>
                        <label>Before image
                          <input type="file" name="beforeShot_<%= sizeKey %>" accept="image/*">
                        </label>
                        <% if (page.beforeShots && page.beforeShots[sizeKey]) { %>
                          <p class="muted">Current Before: <a href="<%= page.beforeShots[sizeKey] %>" target="_blank" rel="noopener">view</a></p>
                          <label class="remove-toggle"><input type="checkbox" name="removeBeforeShot_<%= sizeKey %>" value="true"> Remove Before</label>
                        <% } %>
                        <label>After image
                          <input type="file" name="afterShot_<%= sizeKey %>" accept="image/*">
                        </label>
                        <% if (page.afterShots && page.afterShots[sizeKey]) { %>
                          <p class="muted">Current After: <a href="<%= page.afterShots[sizeKey] %>" target="_blank" rel="noopener">view</a></p>
                          <label class="remove-toggle"><input type="checkbox" name="removeAfterShot_<%= sizeKey %>" value="true"> Remove After</label>
                        <% } %>
                      </fieldset>
                    <% }) %>
                    <button type="submit">Save uploaded images</button>
                  </form>
                </details>
              <% } %>

              <% if (page.type === 'urlCompare') { %>
                <p class="muted"><strong>One URL comparison only:</strong> this page should have one Dev URL and one Live URL.</p>
                <label>
                  Instructions
                  <textarea name="instructions"><%= page.instructions || '' %></textarea>
                </label>

                <label>
                  Dev URL
                  <input type="text" name="devUrl" inputmode="url" list="review-url-options" value="<%= page.devUrl || '' %>" placeholder="https://dev-example.pantheonsite.io or /public/demo/dev-home.html">
                </label>

                <label>
                  Live URL
                  <input type="text" name="liveUrl" inputmode="url" list="review-url-options" value="<%= page.liveUrl || '' %>" placeholder="https://www.example.com or /public/demo/live-home.html">
                </label>

                <details class="advanced-tools">
                  <summary>Preview fallback</summary>
                  <p class="muted">Use this only when iframe previews are blocked or you need a static visual reference.</p>

                  <p class="muted">Current Dev screenshot: <%= page.devScreenshotPath || 'None' %></p>
                  <label>
                    Replace Dev screenshot
                    <input type="file" name="devScreenshot" accept="image/*">
                  </label>
                  <% if (page.devScreenshotPath) { %>
                    <label class="remove-toggle">
                      <input type="checkbox" name="removeDevScreenshot" value="true"> Remove Dev screenshot
                    </label>
                  <% } %>

                  <p class="muted">Current Live screenshot: <%= page.liveScreenshotPath || 'None' %></p>
                  <label>
                    Replace Live screenshot
                    <input type="file" name="liveScreenshot" accept="image/*">
                  </label>
                  <% if (page.liveScreenshotPath) { %>
                    <label class="remove-toggle">
                      <input type="checkbox" name="removeLiveScreenshot" value="true"> Remove Live screenshot
                    </label>
                  <% } %>
                </details>
              <% } %>

              <button type="submit">Save Page Changes</button>
            </form>

            <% if (page.type === 'urlCompare' || page.type === 'imageCompare') { %>
              <% const highlightPresetList = [['desktop','Full desktop'],['laptop-15-6','15.6 display'],['laptop-14-5','14.5 display'],['laptop-13','13 display'],['mobile','Mobile']]; %>
              <details class="advanced-tools highlight-admin">
                <summary>Reviewer highlights</summary>
                <p class="muted">Add saved callouts that reviewers will see on this comparison. Positions are percentages of the preview area.</p>

                <% if (page.highlights && page.highlights.length) { %>
                  <div class="highlight-list">
                    <% page.highlights.forEach(highlight => { %>
                      <form class="highlight-row" method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/highlights/<%= highlight.highlightId %>/delete">
                        <input type="hidden" name="key" value="<%= key %>">
                        <span><strong><%= highlight.type || 'box' %></strong> · <%= highlight.screenSize || 'desktop' %> · <%= highlight.label || 'No label' %></span>
                        <button type="submit" class="danger">Delete</button>
                      </form>
                    <% }) %>
                  </div>
                <% } else { %>
                  <p class="muted">No saved highlights yet.</p>
                <% } %>

                <form class="highlight-form" method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/highlights">
                  <input type="hidden" name="key" value="<%= key %>">
                  <label>Label <input type="text" name="label" placeholder="Example: Check headline spacing"></label>
                  <label>Shape
                    <select name="type">
                      <option value="box">Translucent box</option>
                      <option value="underline">Underline</option>
                      <option value="arrow">Arrow</option>
                    </select>
                  </label>
                  <label>Screen size
                    <select name="screenSize">
                      <% highlightPresetList.forEach(([sizeKey, sizeLabel]) => { %>
                        <option value="<%= sizeKey %>"><%= sizeLabel %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label>Arrow direction
                    <select name="direction">
                      <option value="right">Right</option>
                      <option value="left">Left</option>
                      <option value="down">Down</option>
                      <option value="up">Up</option>
                    </select>
                  </label>
                  <label>X % <input type="number" name="x" value="12" min="0" max="100" step="0.1"></label>
                  <label>Y % <input type="number" name="y" value="18" min="0" max="100" step="0.1"></label>
                  <label>Width % <input type="number" name="width" value="24" min="0" max="100" step="0.1"></label>
                  <label>Height % <input type="number" name="height" value="12" min="0" max="100" step="0.1"></label>
                  <button type="submit">Add highlight</button>
                </form>
              </details>
            <% } %>

            <% if (page.type === 'urlCompare') { %>
              <details class="capture-block advanced-tools">
                <summary>Screenshot fallbacks by screen size</summary>
                <h4>Capture from URLs</h4>
                <p class="muted">Capture full page screenshots at each review size. Save the URLs above first. Recapture when the site updates.</p>

                <form method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/capture">
                  <input type="hidden" name="key" value="<%= key %>">
                  <button type="submit">
                    <%= (page.devShots || page.liveShots) ? 'Recapture screenshots from URLs' : 'Capture screenshots from URLs' %>
                  </button>
                </form>

                <% if (page.capturedAt) { %>
                  <p class="muted">Last captured: <%= page.capturedAt %></p>
                <% } %>

                <% const presetList = [['desktop','Full desktop'],['laptop-15-6','15.6 display'],['laptop-14-5','14.5 display'],['laptop-13','13 display'],['mobile','Mobile']]; %>

                <% if (page.devShots || page.liveShots) { %>
                  <div class="capture-grid">
                    <% presetList.forEach(([sizeKey, sizeLabel]) => { %>
                      <div class="capture-cell">
                        <p class="capture-cell__label"><%= sizeLabel %></p>
                        <div class="capture-thumbs">
                          <% if (page.devShots && page.devShots[sizeKey]) { %>
                            <a href="<%= page.devShots[sizeKey] %>" target="_blank" rel="noopener">Dev</a>
                          <% } else { %>
                            <span class="muted">No Dev</span>
                          <% } %>
                          <% if (page.liveShots && page.liveShots[sizeKey]) { %>
                            <a href="<%= page.liveShots[sizeKey] %>" target="_blank" rel="noopener">Live</a>
                          <% } else { %>
                            <span class="muted">No Live</span>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>

                <h4>Manual upload by screen size</h4>
                <p class="muted">Use manual uploads only when capture cannot reach the site.</p>
                <form method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/upload-shots?key=<%= encodeURIComponent(key) %>" enctype="multipart/form-data">
                  <input type="hidden" name="key" value="<%= key %>">
                  <% presetList.forEach(([sizeKey, sizeLabel]) => { %>
                    <fieldset class="shot-upload">
                      <legend><%= sizeLabel %></legend>
                      <label>Dev screenshot
                        <input type="file" name="devShot_<%= sizeKey %>" accept="image/*">
                      </label>
                      <% if (page.devShots && page.devShots[sizeKey]) { %>
                        <p class="muted">Current Dev: <a href="<%= page.devShots[sizeKey] %>" target="_blank" rel="noopener">view</a></p>
                        <label class="remove-toggle"><input type="checkbox" name="removeDevShot_<%= sizeKey %>" value="true"> Remove Dev</label>
                      <% } %>
                      <label>Live screenshot
                        <input type="file" name="liveShot_<%= sizeKey %>" accept="image/*">
                      </label>
                      <% if (page.liveShots && page.liveShots[sizeKey]) { %>
                        <p class="muted">Current Live: <a href="<%= page.liveShots[sizeKey] %>" target="_blank" rel="noopener">view</a></p>
                        <label class="remove-toggle"><input type="checkbox" name="removeLiveShot_<%= sizeKey %>" value="true"> Remove Live</label>
                      <% } %>
                    </fieldset>
                  <% }) %>
                  <button type="submit">Save uploaded screenshots</button>
                </form>
              </details>
            <% } %>
          </article>
        <% }) %>

        <% if (!packet.pages.length) { %>
          <p>No pages yet. Add a cover page first, then add a comparison page.</p>
        <% } %>
      </section>
    </main>
    <style>
      .admin-simple-flow {
        margin-bottom: 1rem;
      }

      .admin-simple-flow h2 {
        margin-bottom: 0.5rem;
      }

      .admin-simple-flow p {
        margin: 0.4rem 0;
      }

      .advanced-tools {
        margin-top: 1rem;
        border: 1px solid rgba(15, 23, 42, 0.12);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        background: #fafafa;
      }

      .advanced-tools summary {
        cursor: pointer;
        font-weight: 600;
      }

      .advanced-tools[open] summary {
        margin-bottom: 0.75rem;
      }

      .highlight-list {
        display: grid;
        gap: 0.5rem;
        margin-bottom: 1rem;
      }

      .highlight-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.65rem 0.75rem;
        border: 1px solid rgba(15, 23, 42, 0.1);
        border-radius: 10px;
        background: #fff;
      }

      .highlight-row span {
        min-width: 0;
      }

      .highlight-row button {
        width: auto;
        flex: 0 0 auto;
      }

      .highlight-form {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 0.75rem;
      }

      .highlight-form label:first-of-type {
        grid-column: 1 / -1;
      }

      .highlight-form button {
        align-self: end;
      }
    </style>
  </body>
</html>
