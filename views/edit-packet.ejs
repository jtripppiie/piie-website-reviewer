<!doctype html>
<html lang="en">
  <%- include('partials/head', { title: 'Edit Packet' }) %>
  <body>
    <main class="shell">
      <p><a href="/admin?key=<%= key %>">Back to admin</a></p>

      <h1>Edit Packet</h1>

      <section class="card admin-simple-flow">
        <h2>Simple editing flow</h2>
        <p>Keep this page to one job at a time.</p>
        <p><strong>For a URL review page:</strong> set the title, set the instructions, enter one Dev URL and one Live URL, then save.</p>
        <p>Only use screenshot capture or per-size uploads if the site preview is blocked or you need manual fallbacks.</p>
      </section>

      <section class="card">
        <h2>Packet Details</h2>

        <form method="post" action="/admin/packets/<%= packet.packetId %>/update">
          <input type="hidden" name="key" value="<%= key %>">

          <label>
            Packet title
            <input type="text" name="title" value="<%= packet.title %>" required>
          </label>

          <button type="submit">Save Packet Details</button>
        </form>
      </section>

      <section class="card">
        <p>Status: <strong><%= packet.published ? 'Published' : 'Draft' %></strong></p>

        <form method="post" action="/admin/packets/<%= packet.packetId %>/publish">
          <input type="hidden" name="key" value="<%= key %>">
          <input type="hidden" name="published" value="<%= packet.published ? 'false' : 'true' %>">
          <button type="submit"><%= packet.published ? 'Unpublish' : 'Publish' %></button>
        </form>

        <% if (packet.published) { %>
          <p>Share link: <a href="/r/<%= packet.shareToken %>">/r/<%= packet.shareToken %></a></p>
        <% } else { %>
          <p class="muted">Publish the packet when it is ready for reviewers.</p>
        <% } %>
      </section>

      <h2>Add New Page</h2>

      <section class="grid">
        <form class="card" method="post" action="/admin/packets/<%= packet.packetId %>/cover">
          <input type="hidden" name="key" value="<%= key %>">
          <h3>Add Cover Page</h3>

          <label>Title <input type="text" name="title" required></label>
          <label>Subtitle <input type="text" name="subtitle"></label>
          <label>Body <textarea name="body"></textarea></label>

          <button type="submit">Add Cover</button>
        </form>

        <form class="card" method="post" action="/admin/packets/<%= packet.packetId %>/image-compare" enctype="multipart/form-data">
          <input type="hidden" name="key" value="<%= key %>">
          <h3>Add Screenshot Comparison</h3>

          <label>Title <input type="text" name="title" required></label>
          <label>Instructions <textarea name="instructions"></textarea></label>
          <label>Before label <input type="text" name="beforeLabel" value="Before"></label>
          <label>After label <input type="text" name="afterLabel" value="After"></label>
          <label>Before image <input type="file" name="beforeImage" accept="image/*" required></label>
          <label>After image <input type="file" name="afterImage" accept="image/*" required></label>

          <button type="submit">Add Images</button>
        </form>

        <form class="card" method="post" action="/admin/packets/<%= packet.packetId %>/url-compare" enctype="multipart/form-data">
          <input type="hidden" name="key" value="<%= key %>">
          <h3>Add Dev vs Live Review</h3>

          <label>Title <input type="text" name="title" required></label>
          <label>Instructions <textarea name="instructions"></textarea></label>
          <label>Dev URL <input type="url" name="devUrl" placeholder="https://dev-example.pantheonsite.io"></label>
          <label>Live URL <input type="url" name="liveUrl" placeholder="https://www.example.com"></label>

          <p class="muted">Upload screenshots if iframe previews are blocked.</p>

          <label>Dev screenshot (optional) <input type="file" name="devScreenshot" accept="image/*"></label>
          <label>Live screenshot (optional) <input type="file" name="liveScreenshot" accept="image/*"></label>

          <button type="submit">Add Dev vs Live</button>
        </form>
      </section>

      <h2>Edit Existing Pages</h2>

      <section class="stack">
        <% packet.pages.forEach((page, index) => { %>
          <article class="card" id="page-<%= page.pageId %>">
            <p class="eyebrow">Page <%= index + 1 %>: <%= page.type %></p>

            <form method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/update" enctype="multipart/form-data">
              <input type="hidden" name="key" value="<%= key %>">

              <label>
                Title
                <input type="text" name="title" value="<%= page.title || '' %>" required>
              </label>

              <% if (page.type === 'cover') { %>
                <label>
                  Subtitle
                  <input type="text" name="subtitle" value="<%= page.subtitle || '' %>">
                </label>

                <label>
                  Body
                  <textarea name="body"><%= page.body || '' %></textarea>
                </label>
              <% } %>

              <% if (page.type === 'imageCompare') { %>
                <% const presetList = [['desktop','Desktop'],['laptop-15-6','15.6 display'],['laptop-14-5','14.5 display'],['laptop-13','13 display'],['mobile','Mobile']]; %>
                <p class="muted">This page is one image comparison: one Before image and one After image.</p>
                <label>
                  Instructions
                  <textarea name="instructions"><%= page.instructions || '' %></textarea>
                </label>

                <label>
                  Before label
                  <input type="text" name="beforeLabel" value="<%= page.beforeLabel || 'Before' %>">
                </label>

                <label>
                  After label
                  <input type="text" name="afterLabel" value="<%= page.afterLabel || 'After' %>">
                </label>

                <p class="muted">Current before image: <%= page.beforeImagePath || 'None' %></p>
                <label>
                  Replace before image
                  <input type="file" name="beforeImage" accept="image/*">
                </label>
                <% if (page.beforeImagePath) { %>
                  <label class="remove-toggle">
                    <input type="checkbox" name="removeBeforeImage" value="true"> Remove before image
                  </label>
                <% } %>

                <p class="muted">Current after image: <%= page.afterImagePath || 'None' %></p>
                <label>
                  Replace after image
                  <input type="file" name="afterImage" accept="image/*">
                </label>
                <% if (page.afterImagePath) { %>
                  <label class="remove-toggle">
                    <input type="checkbox" name="removeAfterImage" value="true"> Remove after image
                  </label>
                <% } %>

                <details class="advanced-tools">
                  <summary>Optional per-size image uploads</summary>
                  <p class="muted">Upload separate Before and After images for Desktop, 15.6, 14.5, 13, and Mobile only when you need size-specific assets.</p>
                  <form method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/upload-shots" enctype="multipart/form-data">
                    <input type="hidden" name="key" value="<%= key %>">
                    <% presetList.forEach(([sizeKey, sizeLabel]) => { %>
                      <fieldset class="shot-upload">
                        <legend><%= sizeLabel %></legend>
                        <label>Before image
                          <input type="file" name="beforeShot_<%= sizeKey %>" accept="image/*">
                        </label>
                        <% if (page.beforeShots && page.beforeShots[sizeKey]) { %>
                          <p class="muted">Current Before: <a href="<%= page.beforeShots[sizeKey] %>" target="_blank" rel="noopener">view</a></p>
                          <label class="remove-toggle"><input type="checkbox" name="removeBeforeShot_<%= sizeKey %>" value="true"> Remove Before</label>
                        <% } %>
                        <label>After image
                          <input type="file" name="afterShot_<%= sizeKey %>" accept="image/*">
                        </label>
                        <% if (page.afterShots && page.afterShots[sizeKey]) { %>
                          <p class="muted">Current After: <a href="<%= page.afterShots[sizeKey] %>" target="_blank" rel="noopener">view</a></p>
                          <label class="remove-toggle"><input type="checkbox" name="removeAfterShot_<%= sizeKey %>" value="true"> Remove After</label>
                        <% } %>
                      </fieldset>
                    <% }) %>
                    <button type="submit">Save uploaded images</button>
                  </form>
                </details>
              <% } %>

              <% if (page.type === 'urlCompare') { %>
                <p class="muted"><strong>One URL comparison only:</strong> this page should have one Dev URL and one Live URL.</p>
                <label>
                  Instructions
                  <textarea name="instructions"><%= page.instructions || '' %></textarea>
                </label>

                <label>
                  Dev URL
                  <input type="url" name="devUrl" value="<%= page.devUrl || '' %>">
                </label>

                <label>
                  Live URL
                  <input type="url" name="liveUrl" value="<%= page.liveUrl || '' %>">
                </label>

                <details class="advanced-tools">
                  <summary>Optional basic screenshot replacements</summary>
                  <p class="muted">Use these only if you want one manual Dev screenshot and one manual Live screenshot for the page.</p>

                  <p class="muted">Current Dev screenshot: <%= page.devScreenshotPath || 'None' %></p>
                  <label>
                    Replace Dev screenshot
                    <input type="file" name="devScreenshot" accept="image/*">
                  </label>
                  <% if (page.devScreenshotPath) { %>
                    <label class="remove-toggle">
                      <input type="checkbox" name="removeDevScreenshot" value="true"> Remove Dev screenshot
                    </label>
                  <% } %>

                  <p class="muted">Current Live screenshot: <%= page.liveScreenshotPath || 'None' %></p>
                  <label>
                    Replace Live screenshot
                    <input type="file" name="liveScreenshot" accept="image/*">
                  </label>
                  <% if (page.liveScreenshotPath) { %>
                    <label class="remove-toggle">
                      <input type="checkbox" name="removeLiveScreenshot" value="true"> Remove Live screenshot
                    </label>
                  <% } %>
                </details>
              <% } %>

              <button type="submit">Save Page Changes</button>
            </form>

            <% if (page.type === 'urlCompare') { %>
              <details class="capture-block advanced-tools">
                <summary>Advanced screenshot tools</summary>
                <h4>Auto screenshots</h4>
                <p class="muted">Capture full page screenshots of the Dev and Live URLs at every preset (Desktop, 15.6, 14.5, 13, Mobile). Save the URLs above first. Recapture any time after the site updates.</p>

                <form method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/capture">
                  <input type="hidden" name="key" value="<%= key %>">
                  <button type="submit">
                    <%= (page.devShots || page.liveShots) ? 'Recapture screenshots from URLs' : 'Capture screenshots from URLs' %>
                  </button>
                </form>

                <% if (page.capturedAt) { %>
                  <p class="muted">Last captured: <%= page.capturedAt %></p>
                <% } %>

                <% const presetList = [['desktop','Desktop'],['laptop-15-6','15.6 display'],['laptop-14-5','14.5 display'],['laptop-13','13 display'],['mobile','Mobile']]; %>

                <% if (page.devShots || page.liveShots) { %>
                  <div class="capture-grid">
                    <% presetList.forEach(([sizeKey, sizeLabel]) => { %>
                      <div class="capture-cell">
                        <p class="capture-cell__label"><%= sizeLabel %></p>
                        <div class="capture-thumbs">
                          <% if (page.devShots && page.devShots[sizeKey]) { %>
                            <a href="<%= page.devShots[sizeKey] %>" target="_blank" rel="noopener">Dev</a>
                          <% } else { %>
                            <span class="muted">No Dev</span>
                          <% } %>
                          <% if (page.liveShots && page.liveShots[sizeKey]) { %>
                            <a href="<%= page.liveShots[sizeKey] %>" target="_blank" rel="noopener">Live</a>
                          <% } else { %>
                            <span class="muted">No Live</span>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>

                <h4>Upload screenshots by screen size</h4>
                <p class="muted">When you cannot capture the live site, upload a screenshot for each size by hand. These fill the same per size view reviewers see.</p>
                <form method="post" action="/admin/packets/<%= packet.packetId %>/pages/<%= page.pageId %>/upload-shots" enctype="multipart/form-data">
                  <input type="hidden" name="key" value="<%= key %>">
                  <% presetList.forEach(([sizeKey, sizeLabel]) => { %>
                    <fieldset class="shot-upload">
                      <legend><%= sizeLabel %></legend>
                      <label>Dev screenshot
                        <input type="file" name="devShot_<%= sizeKey %>" accept="image/*">
                      </label>
                      <% if (page.devShots && page.devShots[sizeKey]) { %>
                        <p class="muted">Current Dev: <a href="<%= page.devShots[sizeKey] %>" target="_blank" rel="noopener">view</a></p>
                        <label class="remove-toggle"><input type="checkbox" name="removeDevShot_<%= sizeKey %>" value="true"> Remove Dev</label>
                      <% } %>
                      <label>Live screenshot
                        <input type="file" name="liveShot_<%= sizeKey %>" accept="image/*">
                      </label>
                      <% if (page.liveShots && page.liveShots[sizeKey]) { %>
                        <p class="muted">Current Live: <a href="<%= page.liveShots[sizeKey] %>" target="_blank" rel="noopener">view</a></p>
                        <label class="remove-toggle"><input type="checkbox" name="removeLiveShot_<%= sizeKey %>" value="true"> Remove Live</label>
                      <% } %>
                    </fieldset>
                  <% }) %>
                  <button type="submit">Save uploaded screenshots</button>
                </form>
              </details>
            <% } %>
          </article>
        <% }) %>

        <% if (!packet.pages.length) { %>
          <p>No pages yet. Add a cover page first, then add a comparison page.</p>
        <% } %>
      </section>
    </main>
    <style>
      .admin-simple-flow {
        margin-bottom: 1rem;
      }

      .admin-simple-flow h2 {
        margin-bottom: 0.5rem;
      }

      .admin-simple-flow p {
        margin: 0.4rem 0;
      }

      .advanced-tools {
        margin-top: 1rem;
        border: 1px solid rgba(15, 23, 42, 0.12);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        background: #fafafa;
      }

      .advanced-tools summary {
        cursor: pointer;
        font-weight: 600;
      }

      .advanced-tools[open] summary {
        margin-bottom: 0.75rem;
      }
    </style>
  </body>
</html>
